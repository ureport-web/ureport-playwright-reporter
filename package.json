{
  "name": "ureport-playwright-reporter",
  "version": "1.3.0",
  "description": "Playwright reporter plugin for UReport — ships test results automatically",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:integration": "npm run build && node_modules/.bin/jest --config jest.integration.config.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "prepublishOnly": "npm run test:all && npm run build"
  },
  "keywords": [
    "playwright",
    "reporter",
    "ureport",
    "testing"
  ],
  "author": "yizhongji@gmail.com",
  "license": "MIT",
  "peerDependencies": {
    "@playwright/test": ">=1.30.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/*.spec.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node"
          }
        }
      ]
    }
  },
  "engines": {
    "node": ">=18"
  }
}
